# All optional — Verdikt runs rules-only without these.
PORT=5174
VERDIKT_DB=verdikt.sqlite
MAX_UPLOAD_BYTES=67108864

# Enable the optional Nuclei security pass (requires the `nuclei` binary on PATH).
# Point at the bundled ChromeAudit templates:
# NUCLEI_TEMPLATES_DIR=./ChromeAudit

# Enable the optional Claude judge for subjective policy categories.
# ANTHROPIC_API_KEY=sk-ant-...
# VERDIKT_CLAUDE_MODEL=claude-opus-4-7
